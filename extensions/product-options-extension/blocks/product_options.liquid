<div class="product-options-box" data-product-options-extension>
  <div class="po-card">
    <h3 class="po-heading">Add Ons</h3>

    <div class="po-addon">
      <label class="po-addon-top">
        <input type="checkbox" class="po-checkbox">
        <div class="po-img"></div>
        <div>
          <p class="po-title">YOUR PRODUCTS TITLE HERE</p>
          <p class="po-price">$18.00 <span>$34.00</span></p>
        </div>
      </label>

      <div class="po-select-row">
        <select>
          <option>Color</option>
          <option>Gray</option>
          <option>Black</option>
        </select>

        <select>
          <option>Element</option>
          <option>Cotton</option>
          <option>Silk</option>
        </select>
      </div>
    </div>

    <div class="po-addon">
      <label class="po-addon-top">
        <input type="checkbox" class="po-checkbox">
        <div class="po-img"></div>
        <div>
          <p class="po-title">YOUR PRODUCTS TITLE HERE</p>
          <p class="po-price">$18.00 <span>$34.00</span></p>
        </div>
      </label>
    </div>

    <div class="po-addon">
      <label class="po-addon-top">
        <input type="checkbox" class="po-checkbox">
        <div class="po-img"></div>
        <div>
          <p class="po-title">YOUR PRODUCTS TITLE HERE</p>
          <p class="po-price">$18.00 <span>$34.00</span></p>
        </div>
      </label>

      <div class="po-select-row three">
        <select>
          <option>Color</option>
        </select>

        <select>
          <option>Size</option>
        </select>

        <select>
          <option>Element</option>
        </select>
      </div>
    </div>

    <h3 class="po-heading custom">Custom fields</h3>

    <div class="po-fields">
      <input type="text" placeholder="Name">
      <input type="number" placeholder="Number">

      <select>
        <option>Select</option>
      </select>

      <input type="date" placeholder="DOB">

      <textarea placeholder="Message"></textarea>
    </div>
  </div>
</div>

<style>
  .product-options-box {
    width: 100%;
    margin-top: 24px;
  }

  .po-card {
    border: 1px solid #dedede;
    border-radius: 24px;
    padding: 26px;
    background: #fff;
  }

  .po-heading {
    margin: 0 0 16px;
    font-size: 20px;
    font-weight: 700;
  }

  .po-heading.custom {
    margin-top: 22px;
  }

  .po-addon {
    border: 1px solid #dedede;
    border-radius: 22px;
    padding: 22px;
    margin-bottom: 16px;
  }

  .po-addon-top {
    display: flex;
    align-items: center;
    gap: 18px;
    cursor: pointer;
  }

  .po-checkbox {
    width: 22px;
    height: 22px;
    accent-color: #111;
    flex-shrink: 0;
  }

  .po-img {
    width: 58px;
    height: 58px;
    border-radius: 10px;
    background: #efefef;
    flex-shrink: 0;
  }

  .po-title {
    margin: 0 0 8px;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .po-price {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    color: #d64c4c;
  }

  .po-price span {
    margin-left: 8px;
    color: #222;
    font-size: 13px;
    text-decoration: line-through;
  }

  .po-select-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 20px;
  }

  .po-select-row.three {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .po-select-row select,
  .po-fields input,
  .po-fields select,
  .po-fields textarea {
    width: 100%;
    min-height: 48px;
    border: 1px solid #cfcfcf;
    border-radius: 12px;
    padding: 0 14px;
    font-size: 14px;
    background: #fff;
  }

  .po-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .po-fields textarea {
    grid-column: 1 / -1;
    min-height: 120px;
    padding-top: 14px;
    resize: vertical;
  }

  @media screen and (max-width: 749px) {
    .po-card {
      padding: 18px;
      border-radius: 18px;
    }

    .po-addon {
      padding: 16px;
      border-radius: 16px;
    }

    .po-select-row,
    .po-select-row.three,
    .po-fields {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Product Options Add-ons",
  "target": "section",
  "settings": []
}
{% endschema %}